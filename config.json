{
  "appName": "TennisCoach AI",
  "version": "1.0.0",
  "model": {
    "provider": "openai",
    "apiUrl": "https://api.openai.com/v1/chat/completions",
    "apiKey": "YOUR_API_KEY_HERE",
    "modelName": "gpt-4o",
    "temperature": 0.7,
    "maxTokens": 4000
  },
  "features": {
    "enableAIGeneration": false,
    "fallbackToRuleBased": true
  },
  "acsmStandards": {
    "beginner": {
      "trainingFrequencyPerWeek": [3, 4],
      "setsRange": [2, 3],
      "repsRange": [10, 15],
      "restBetweenSetsSec": [45, 90],
      "intensityPercent1RM": [40, 60]
    },
    "intermediate": {
      "trainingFrequencyPerWeek": [4, 5],
      "setsRange": [3, 4],
      "repsRange": [8, 12],
      "restBetweenSetsSec": [30, 60],
      "intensityPercent1RM": [60, 80]
    },
    "advanced": {
      "trainingFrequencyPerWeek": [5, 6],
      "setsRange": [3, 5],
      "repsRange": [6, 12],
      "restBetweenSetsSec": [30, 90],
      "intensityPercent1RM": [70, 95]
    }
  },
  "pdf": {
    "format": "A4",
    "margin": "10mm",
    "printScale": 0.95
  }
}
